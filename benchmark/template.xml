<?xml version="1.0"?>
<!DOCTYPE benchmark PUBLIC "+//IDN sosy-lab.org//DTD BenchExec benchmark 2.3//EN" "https://www.sosy-lab.org/benchexec/benchmark-2.3.dtd">
<benchmark tool="treq" displayName="Treq" timelimit="15 min" hardtimelimit="16 min" memlimit="15 GB" cpuCores="4">

  <require cpuModel="CPUMODEL" />
  <option name="--benchmark"/>
  <option name="--no-memcmp"/>

  <!-- DEFINITIONS-->

  <columns>
    <column title="create transformer original">create transformer original: </column>
    <column title="transform original">transform original: </column>
    <column title="create transformer mutant">create transformer mutant: </column>
    <column title="transform mutant">transform mutant: </column>
    <column title="merge">merge: </column>
    <column title="measured total">measured total: </column>
    <column title="total">wall total: </column>
  </columns>
</benchmark>
